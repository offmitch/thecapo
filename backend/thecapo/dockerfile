FROM eclipse-temurin:17-jdk-jammy

WORKDIR /app

# Copy Maven wrapper and settings
COPY mvnw .
COPY .mvn .mvn
COPY pom.xml .

# Give execute permission to mvnw and pre-download dependencies
RUN chmod +x mvnw && ./mvnw dependency:go-offline -B

# Copy source code
COPY src src

# Build the app
RUN ./mvnw package -DskipTests

# Expose port for Render
ENV PORT 8080
EXPOSE $PORT

# Make Spring Boot use Render's PORT variable
ENV JAVA_OPTS="-Dserver.port=$PORT"

# Start the app
CMD java $JAVA_OPTS -jar target/*.jar